# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# sanity
/.sanity/
/dist/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code worktrees (local isolation dirs)
.claude/worktrees/

# memory compiler logs
.claude-memory-compiler/scripts/*.log

# internal reference docs (PII in CSVs — keep local only)
docs/

# large local-only media
public/images/hero/podcast-hero-hires.webp
